<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="#000000">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="$ wg-monitor --version"
        android:textColor="#5FB76E"
        android:textSize="12sp"
        android:fontFamily="monospace"
        android:layout_marginTop="20dp"/>

    <TextView
        android:id="@+id/tv_version"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="WG 流量监控"
        android:textColor="#3FB950"
        android:textSize="22sp"
        android:textStyle="bold"
        android:fontFamily="monospace"
        android:layout_marginTop="6dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="# 长按主屏 -&gt; 小部件 -&gt; WG 流量监控"
        android:textColor="#5FB76E"
        android:textSize="12sp"
        android:fontFamily="monospace"
        android:layout_marginTop="20dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:orientation="horizontal"
        android:background="#1F6F2C"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="20dp"/>

    <Button
        android:id="@+id/btn_test"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="test_api()"
        android:fontFamily="monospace"
        android:textColor="#000000"
        android:backgroundTint="#3FB950"/>

    <Button
        android:id="@+id/btn_refresh"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="refresh_widgets()"
        android:fontFamily="monospace"
        android:textColor="#000000"
        android:backgroundTint="#3FB950"/>

    <Button
        android:id="@+id/btn_update"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="check_update()"
        android:fontFamily="monospace"
        android:textColor="#000000"
        android:backgroundTint="#7EE787"/>

    <TextView
        android:id="@+id/tv_status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:text="# 点击按钮开始"
        android:textColor="#3FB950"
        android:textSize="12sp"
        android:fontFamily="monospace"
        android:padding="12dp"
        android:background="#0A0E0A"/>
</LinearLayout>
