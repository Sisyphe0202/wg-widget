<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/wg_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="12dp"
    android:background="@drawable/widget_bg">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="$ wg quota --remaining"
        android:textColor="#5FB76E"
        android:textSize="10sp"
        android:fontFamily="monospace"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:baselineAligned="false"
        android:gravity="bottom"
        android:layout_marginTop="2dp">

        <TextView
            android:id="@+id/wg_remaining"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="—"
            android:textColor="#3FB950"
            android:textSize="28sp"
            android:textStyle="bold"
            android:fontFamily="monospace"/>

        <TextView
            android:id="@+id/wg_budget"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#7EE787"
            android:textSize="11sp"
            android:layout_marginStart="6dp"
            android:layout_marginBottom="4dp"
            android:fontFamily="monospace"/>
    </LinearLayout>

    <ProgressBar
        android:id="@+id/wg_progress"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="6dp"
        android:layout_marginTop="6dp"
        android:max="100"
        android:progress="0"
        android:progressTint="#3FB950"
        android:progressBackgroundTint="#1F6F2C"/>

    <TextView
        android:id="@+id/wg_reset"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="#5FB76E"
        android:textSize="11sp"
        android:layout_marginTop="6dp"
        android:fontFamily="monospace"/>

    <TextView
        android:id="@+id/wg_peers"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="#3FB950"
        android:textSize="11sp"
        android:layout_marginTop="2dp"
        android:fontFamily="monospace"/>
</LinearLayout>
